# Google Calendar API Credentials
# 1. Go to Google Cloud Console (https://console.cloud.google.com/)
# 2. Create a Project and enable the Google Calendar API
# 3. Create OAuth 2.0 Client IDs under Credentials
# 4. Copy the Client ID and Secret here

GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Note: In production, the REDIRECT_URI should match your deployed domain.
# You will also need to store and manage USER_REFRESH_TOKEN for offline access to their calendars.
